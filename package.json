{
  "name": "relay-frontend",
  "version": "1.0.0",
  "description": "Relay — API Client",
  "author": "Relay Developers",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:start": "concurrently -k \"npm run dev\" \"sleep 3 && npm run electron:dev\"",
    "dist": "vite build && electron-builder",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:win": "vite build && electron-builder --win --x64"
  },
  "dependencies": {
    "pinia": "^2.2.2",
    "vue": "^3.5.4",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.2",
    "concurrently": "^9.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "vite": "^5.4.2"
  },
  "build": {
    "appId": "com.relay.app",
    "productName": "Relay",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
